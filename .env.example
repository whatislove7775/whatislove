# ─── Django ──────────────────────────────────────────────────
SECRET_KEY=your-secret-key-min-50-chars
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ────────────────────────────────────────────────
USE_POSTGRES=True
DB_NAME=anonpsy
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── YooKassa ────────────────────────────────────────────────
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-yookassa-secret
YOOKASSA_RETURN_URL=https://yourdomain.com/session/payment-complete

# ─── Platform ────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=20.0

# ─── CORS (укажи домен Vercel) ────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost,https://yourapp.vercel.app

# ─── Next.js (Vercel — задай в dashboard как env vars) ───────
# Для Vercel+Railway: укажи Railway URL бэкенда
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app/api/v1
NEXT_PUBLIC_WS_URL=wss://your-api.up.railway.app

# Для Docker Compose (локально):
# NEXT_PUBLIC_API_URL=http://localhost/api/v1
# NEXT_PUBLIC_WS_URL=ws://localhost
