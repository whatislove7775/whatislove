# ─── Django ──────────────────────────────────────────────────
SECRET_KEY=your-secret-key-min-50-chars
JWT_SECRET_KEY=your-jwt-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ────────────────────────────────────────────────
DB_NAME=anonpsy
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── YooKassa ────────────────────────────────────────────────
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-yookassa-secret
YOOKASSA_RETURN_URL=https://yourdomain.ru/session/payment-complete

# ─── Platform settings ───────────────────────────────────────
PLATFORM_FEE_PERCENT=20.0

# ─── CORS ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Next.js ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─── SMTP (письмо-подтверждение заказа, напр. почта на Beget) ──
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_USER=noreplay@wh4tislove.ru
SMTP_PASSWORD=your-mailbox-password
SMTP_FROM=noreplay@wh4tislove.ru
