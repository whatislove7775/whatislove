# ─── Django ──────────────────────────────────────────────────
SECRET_KEY=your-secret-key-min-50-chars
JWT_SECRET_KEY=your-jwt-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ────────────────────────────────────────────────
# USE_POSTGRES=False  → SQLite (для локальной разработки, ничего не нужно устанавливать)
# USE_POSTGRES=True   → PostgreSQL (для production)
USE_POSTGRES=False
# DB_NAME=anonpsy
# DB_USER=postgres
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# ─── Redis ───────────────────────────────────────────────────
# Оставь пустым — будет in-memory channel layer (для локалки)
# REDIS_URL=redis://localhost:6379/0

# ─── YooKassa ────────────────────────────────────────────────
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-yookassa-secret
YOOKASSA_RETURN_URL=https://yourdomain.ru/session/payment-complete

# ─── Platform settings ───────────────────────────────────────
PLATFORM_FEE_PERCENT=20.0

# ─── CORS ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost

# ─── Next.js ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/ws
